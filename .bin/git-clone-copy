#!/usr/bin/env bash

set -e

usage() {
    echo "Usage: $(basename "$0") <repo-url> <destination-dir>"
    echo "Clones a git repo and copies contents to destination (without .git), overwriting if it exists."
    exit 1
}

[[ $# -ne 2 ]] && usage

repo="$1"
dest="$2"
tmp=$(mktemp -d)

trap 'rm -rf "$tmp"' EXIT

git clone "$repo" "$tmp"
rm -rf "$tmp/.git"
rm -rf "$dest"
cp -r "$tmp" "$dest"

echo "Done: $repo → $dest"
