#!/usr/bin/env bash
set -euo pipefail

warn() { printf '\033[31m%s\033[0m\n' "$*" >&2; }

usage() {
  cat <<EOF
dots — yadm dotfiles helper

Usage:
  dots status        Show yadm working-tree status
  dots diff          Open all changes in the native macOS diff tool (FileMerge)
  dots edit          Open yadm-managed dotfiles in VS Code
  dots add <path>... Stage files into yadm (bypasses gitignore via -f)
  dots commit        Commit staged changes with message "update"
  dots push          Push commits to the remote
  dots save          Stage all tracked changes, commit "update", and push
  dots init          Re-run the upstream init.sh installer
EOF
}

cmd_status() {
  yadm status
}

cmd_diff() {
  # Directory diff in a single FileMerge window comparing HEAD to the working tree.
  yadm difftool -d -t opendiff -y HEAD
}

cmd_edit() {
  code "$HOME"
}

cmd_add() {
  if [[ "$#" -eq 0 ]]; then
    warn "Usage: dots add <path>..."
    exit 1
  fi
  yadm add -f -- "$@"
}

cmd_commit() {
  yadm commit -m "update"
}

cmd_push() {
  yadm push
}

cmd_save() {
  yadm add -u
  if yadm diff --cached --quiet; then
    echo "Nothing to commit."
    return 0
  fi
  yadm commit -m "update"
  yadm push
}

cmd_init() {
  bash -c "$(curl -fsSL https://raw.githubusercontent.com/lonetis/dots/main/.init.sh)"
}

case "${1:-}" in
  status)            cmd_status ;;
  diff)              cmd_diff ;;
  edit)              cmd_edit ;;
  add)               shift; cmd_add "$@" ;;
  commit)            cmd_commit ;;
  push)              cmd_push ;;
  save)              cmd_save ;;
  init)              cmd_init ;;
  ""|-h|--help|help) usage ;;
  *) warn "Unknown command: $1"; usage >&2; exit 1 ;;
esac
